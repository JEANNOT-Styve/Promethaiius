# Hermes Agent - God Container
FROM nousresearch/hermes-agent:latest

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js for coding agents (Claude Code, Codex, OpenCode)
RUN apt-get update && apt-get install -y curl && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

# Install coding agents globally via npm
RUN npm install -g @anthropic-ai/claude-code @openai/codex-cli opencode

# Create workspace directory
RUN mkdir -p /workspace

# Set working directory
WORKDIR /workspace

# Expose Hermes port (if needed)
EXPOSE 8080

# Start Hermes
CMD ["hermes", "agent"]
