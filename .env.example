# Promethaiius - Environment Variables
# Copy to .env and adjust as needed

# ==========================================
# GitHub Authentication (for git operations)
# ==========================================
GITHUB_TOKEN=

# ==========================================
# Telegram Bot Configuration
# ==========================================
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram user IDs allowed to use the bot
# Get your ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=

# ==========================================
# Models Directory (bind mount for vLLM)
# ==========================================
# Path to your local models folder on the host
MODELS_DIR=/path/to/your/models

# ==========================================
# vLLM Configuration - DiffusionGemma Optimisé
# ==========================================
# Hugging Face token (required for downloading gated models)
HF_TOKEN=***

# Official NousResearch configuration parameters:
# --max-model-len 65000 (reduced from 100k to respect your LM Studio limit)
# --gpu-memory-utilization 0.70 (~22GB on 31.5GB VRAM)
# --attention-backend TRITON_ATTN (officially recommended by NousResearch)
# --diffusion-config '{"canvas_length": 256, "max_denoising_steps": 48}'

# ==========================================
# API Keys & Providers
# ==========================================
# OpenAI API key (used by Hermes for tool use/function calling)
OPENAI_API_KEY=

# Anthropic API key (optional, for Claude integration)
ANTHROPIC_API_KEY=

# ==========================================
# Workspace Configuration
# ==========================================
# URL of the vLLM inference engine (Docker service name)
# Do NOT change to localhost:8000 inside the hermes container
OPENAI_BASE_URL=http://vllm:8000/v1

# Absolute path to the workspace directory inside the container
WORKSPACE_DIR=/workspace

# ==========================================
# IMPORTANT : Context Window Limit
# ==========================================
# MAX 65000 tokens - DO NOT EXCEED!
# Your LM Studio backend limits context window to this value.
# Exceeding will cause OOM (Out Of Memory) errors.
